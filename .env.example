# Copy this file to .env and fill in your values.
# cp .env.example .env   (Mac/Linux)
# copy .env.example .env (Windows)

# Your Atlassian account email (same one you use to log into Jira)
JIRA_EMAIL=you@company.com

# API token — create at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_api_token_here

# Jira Cloud site URL (no trailing slash)
JIRA_BASE_URL=https://dataunveil.atlassian.net

# Server bind address — 0.0.0.0 lets teammates on your LAN open the dashboard
HOST=0.0.0.0
PORT=8080

# Auto-refresh interval in seconds (frontend also polls at this rate)
AUTO_REFRESH_SECONDS=30
